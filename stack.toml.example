# stack.toml — master configuration for the MCP server stack
# Copy to stack.toml and fill in secrets. stack.toml is gitignored.

# ── Active profiles ─────────────────────────────────────────────────────────────
# Enabled optional components. Valid values:
#   "postgres"  — start a shared PostgreSQL+pgvector container
#   "keycloak"  — start Keycloak + its internal PostgreSQL (mutually exclusive with logto)
#   "logto"     — start Logto + its internal PostgreSQL  (mutually exclusive with keycloak)
#   "llama"     — start llama-server container for embeddings
profiles = ["postgres", "keycloak", "llama"]

# ── Runtime ────────────────────────────────────────────────────────────────────
[runtime]
# "podman" | "docker" | omit for auto-detect (prefers podman)
engine = "podman"

# ── PostgreSQL (shared) ─────────────────────────────────────────────────────────
# Used when "postgres" is in profiles.
# When "postgres" is NOT in profiles, all fields must point to an external instance.
[postgres]
image    = "docker.io/pgvector/pgvector:pg17"
host     = "localhost"
port     = 5432
user     = "support"
password = "changeme"       # REQUIRED: change before using in shared environments
database = "support"
data_volume = "stack-pgdata"  # named volume; leave empty to use data_dir instead
# data_dir = "/path/on/host"

# ── llama-server ────────────────────────────────────────────────────────────────
[llama]
image       = "ghcr.io/ggml-org/llama.cpp:server"
host_port   = 16000
models_dir  = "/path/to/models"          # REQUIRED: directory containing GGUF files
embed_model = "mxbai-embed-large-v1-f16.gguf"
gen_model   = ""                          # optional generation model; leave empty to disable
extra_flags = ""                          # verbatim flags appended to llama-server (e.g. "-ngl 99")

# ── Keycloak ────────────────────────────────────────────────────────────────────
[keycloak]
port             = 8080
db_port          = 5434
admin_user       = "admin"
admin_password   = "admin"                # REQUIRED: change for shared environments
realm            = "dev"
api_client_id    = "my-api"              # resource server client ID (becomes aud claim)
m2m_client_id    = "my-app"             # M2M caller client ID
m2m_client_secret = "changeme-dev-secret" # REQUIRED: change for shared environments
token_lifetime   = 3600
hostname         = "localhost"

# ── Logto ─────────────────────────────────────────────────────────────────────
[logto]
port           = 3001
admin_port     = 3002
db_port        = 5435
endpoint       = "http://localhost:3001"
admin_endpoint = "http://localhost:3002"
app_id         = ""          # fill in after first-boot admin console setup
app_secret     = ""          # fill in after first-boot admin console setup
audience       = "https://my-service"
mgmt_app_id     = ""         # optional management API M2M app
mgmt_app_secret = ""

# ── RAG MCP Server ──────────────────────────────────────────────────────────────
[rag_mcp_server]
port          = 15080
log_level     = "info"

# Which OIDC provider validates JWTs: "keycloak" | "logto"
# Must match one of the active profiles, or set the override fields below.
auth_provider = "keycloak"

# Override auth fields when auth_provider profile is NOT in profiles
# (i.e. using an external OIDC instance):
# auth_jwks_url = "https://external-keycloak/realms/myrealm/protocol/openid-connect/certs"
# auth_issuer   = "https://external-keycloak/realms/myrealm"
# auth_audience = "my-api"

[rag_mcp_server.search]
probes             = 4
retrieval_pool_size = 20
rrf_constant       = 60

[rag_mcp_server.reranker]
enabled = false
host    = "http://localhost:8081"

[rag_mcp_server.guardrails]
corpus_topic    = ""
min_topic_score = 0.25
min_match_score = 0.0

[rag_mcp_server.hyde]
enabled       = false
model         = "claude-haiku-4-5-20251001"
base_url      = ""
system_prompt = ""

# ── docs2vector ─────────────────────────────────────────────────────────────────
[docs2vector]
docs_dir       = "/path/to/docs"   # REQUIRED: host directory to ingest
chunk_size     = 512
embed_model    = "mxbai-embed-large-v1"
query_prefix   = ""
passage_prefix = ""

# ── Secrets ──────────────────────────────────────────────────────────────────────
[secrets]
# Required only when rag_mcp_server.hyde.enabled = true
anthropic_api_key = ""
